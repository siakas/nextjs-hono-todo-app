datasource db {
  provider = "sqlite" // プロバイダーを sqlite に変更
  url      = env("DATABASE_URL") // 環境変数からURLを読み込む
}

generator client {
  provider = "prisma-client-js"
}

// Todo モデル定義 (仕様書に基づき追加・編集)
model Todo {
  id        String   @id @default(cuid()) // ID のデフォルト生成方法を cuid に変更 (ULID は直接サポートされていないため代替)
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

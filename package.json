{
  "name": "nextjs-hono-todo-app",
  "version": "1.0.0",
  "private": true,
  "description": "Modern Todo Application with Hono and Next.js",
  "scripts": {
    "dev": "docker compose up",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "volta": {
    "node": "22.17.0"
  }
}
